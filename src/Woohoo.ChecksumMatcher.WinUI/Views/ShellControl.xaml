<UserControl
    x:Class="Woohoo.ChecksumMatcher.WinUI.Views.ShellControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:Woohoo.ChecksumMatcher.WinUI.Behaviors"
    xmlns:ct="using:CommunityToolkit.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:Woohoo.ChecksumMatcher.WinUI.Helpers"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TitleBar
            x:Name="titleBar"
            x:Uid="MainWindow_TitleBar"
            ActualThemeChanged="TitleBar_ActualThemeChanged"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="True"
            IsPaneToggleButtonVisible="False"
            Loaded="TitleBar_Loaded">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Tiles/app-logo.ico" />
            </TitleBar.IconSource>
        </TitleBar>
        <NavigationView
            x:Name="navView"
            Grid.Row="1"
            Header="{x:Bind NavigationSelectedHeader, Mode=OneWay}"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="False"
            IsPaneToggleButtonVisible="True"
            IsPaneVisible="True"
            IsSettingsVisible="True"
            SelectedItem="{x:Bind NavigationSelectedItem, Mode=OneWay}">
            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <Grid Margin="0,-10,0,0">
                        <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="{Binding}" />
                    </Grid>
                </DataTemplate>
            </NavigationView.HeaderTemplate>
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Uid="Shell_Main"
                    helpers:NavigationHelper.NavigateTo="Woohoo.ChecksumMatcher.WinUI.ViewModels.MainViewModel"
                    Icon="{ct:FontIcon Glyph=&#xE80F;}" />
                <NavigationViewItem
                    x:Uid="Shell_Databases"
                    helpers:NavigationHelper.NavigateTo="Woohoo.ChecksumMatcher.WinUI.ViewModels.DatabaseLibraryViewModel"
                    Icon="{ct:FontIcon Glyph=&#xE8F1;}" />
                <NavigationViewItem
                    x:Uid="Shell_CreateDatabase"
                    helpers:NavigationHelper.NavigateTo="Woohoo.ChecksumMatcher.WinUI.ViewModels.DatabaseCreateViewModel"
                    Icon="{ct:FontIcon Glyph=&#xECC8;}" />
                <NavigationViewItem
                    x:Uid="Shell_OfflineExplorer"
                    helpers:NavigationHelper.NavigateTo="Woohoo.ChecksumMatcher.WinUI.ViewModels.OfflineExplorerViewModel"
                    Icon="{ct:FontIcon Glyph=&#xEDA2;}" />
                <NavigationViewItem
                    x:Uid="Shell_CreateDisk"
                    helpers:NavigationHelper.NavigateTo="Woohoo.ChecksumMatcher.WinUI.ViewModels.OfflineExplorerCreateDiskViewModel"
                    Icon="{ct:FontIcon Glyph=&#xECC8;}" />
                <NavigationViewItem
                    x:Uid="Shell_HashCalculator"
                    helpers:NavigationHelper.NavigateTo="Woohoo.ChecksumMatcher.WinUI.ViewModels.HashCalculatorViewModel"
                    Icon="{ct:FontIcon Glyph=&#xE8EF;}" />
                <NavigationViewItem
                    x:Uid="Shell_History"
                    helpers:NavigationHelper.NavigateTo="Woohoo.ChecksumMatcher.WinUI.ViewModels.HistoryViewModel"
                    Icon="{ct:FontIcon Glyph=&#xE81C;}" />
            </NavigationView.MenuItems>
            <Grid Margin="{StaticResource NavigationViewPageContentMargin}">
                <Frame x:Name="navFrame" Background="Transparent" />
            </Grid>
        </NavigationView>
    </Grid>
</UserControl>
